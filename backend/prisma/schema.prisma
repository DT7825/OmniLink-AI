generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String              @id @default(cuid())
  fullName              String
  email                 String              @unique
  passwordHash          String
  phone                 String?
  profileImage          String?
  role                  UserRole            @default(CITIZEN)
  status                UserStatus          @default(PENDING)
  isVerified            Boolean             @default(false)
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  deletedAt             DateTime?
  address               String?
  bio                   String?
  city                  String?
  country               String?
  latitude              Float?
  longitude             Float?
  pincode               String?
  state                 String?
  auditLogs             AuditLog[]
  refreshTokens         RefreshToken[]
  sessions              UserSession[]
  verificationTokens    VerificationToken[]
  citizenProfile        CitizenProfile?
  volunteerProfile      VolunteerProfile?
  ngoProfile            NGOProfile?
  donorProfile          DonorProfile?
  emergencyRequests     EmergencyRequest[]  @relation("CreatedEmergencies")
  volunteerAssignments  EmergencyRequest[]  @relation("VolunteerAssignments")
  ngoAssignments        EmergencyRequest[]  @relation("NgoAssignments")
  notificationsReceived Notification[]      @relation("NotificationReceiver")
  notificationsSent     Notification[]      @relation("NotificationSender")
}

model UserSession {
  id           String   @id @default(cuid())
  userId       String
  accessToken  String
  refreshToken String
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())
  expiresAt    DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  id        String           @id @default(cuid())
  token     String           @unique
  type      VerificationType
  userId    String
  expiresAt DateTime
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String?
  entityId  String?
  metadata  Json?
  ipAddress String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId])
}

enum UserRole {
  CITIZEN
  VOLUNTEER
  NGO
  DONOR
  GOVERNMENT
  ADMIN
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
  DEACTIVATED
}

enum VerificationType {
  EMAIL
  PASSWORD_RESET
}

enum EmergencyCategory {
  MEDICAL
  FIRE
  ACCIDENT
  BLOOD
  ANIMAL_RESCUE
  NATURAL_DISASTER
  FOOD
  SHELTER
  OTHER
}

enum EmergencyPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum EmergencyStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  RESOLVED
  CANCELLED
}

enum NotificationType {
  EMERGENCY
  VOLUNTEER
  NGO
  DONATION
  BLOOD_REQUEST
  SYSTEM
}

enum NotificationPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model CitizenProfile {
  id String @id @default(cuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  gender      String?
  dateOfBirth DateTime?
  bloodGroup  String?

  address String
  city    String
  state   String
  pinCode String

  emergencyContact String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VolunteerProfile {
  id String @id @default(cuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  skills       String[]
  availability String?
  experience   String?
  occupation   String?
  organization String?

  isVerified Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NGOProfile {
  id String @id @default(cuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  ngoName        String
  registrationNo String?
  website        String?
  description    String?

  address String
  city    String
  state   String
  pinCode String

  isVerified Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DonorProfile {
  id String @id @default(cuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  bloodGroup       String
  isAvailable      Boolean   @default(true)
  lastDonationDate DateTime?

  address String
  city    String
  state   String
  pinCode String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EmergencyRequest {
  id String @id @default(cuid())

  title       String
  description String

  category EmergencyCategory
  priority EmergencyPriority @default(MEDIUM)
  status   EmergencyStatus   @default(OPEN)

  address String
  city    String
  state   String
  pinCode String

  latitude  Float?
  longitude Float?

  contactName  String
  contactPhone String

  peopleAffected Int @default(1)

  requiresMedicalAid     Boolean @default(false)
  requiresBlood          Boolean @default(false)
  requiresFood           Boolean @default(false)
  requiresShelter        Boolean @default(false)
  requiresTransportation Boolean @default(false)

  createdById String

  createdBy User @relation(name: "CreatedEmergencies", fields: [createdById], references: [id], onDelete: Cascade)

  assignedVolunteerId String?

  assignedVolunteer User? @relation(name: "VolunteerAssignments", fields: [assignedVolunteerId], references: [id])

  assignedNgoId String?

  assignedNgo User? @relation(name: "NgoAssignments", fields: [assignedNgoId], references: [id])

  assignedNgoAt DateTime?

  assignedAt DateTime?
  resolvedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  notifications Notification[]

  @@index([createdById])
  @@index([assignedVolunteerId])
  @@index([status])
  @@index([category])
}

model Notification {
  id String @id @default(cuid())

  title   String
  message String

  type     NotificationType
  priority NotificationPriority @default(MEDIUM)

  isRead Boolean @default(false)

  receiverId String
  receiver   User   @relation("NotificationReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  senderId String?
  sender   User?   @relation("NotificationSender", fields: [senderId], references: [id])

  emergencyId String?
  emergency   EmergencyRequest? @relation(fields: [emergencyId], references: [id])
  actionUrl   String?
  metadata    Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([receiverId])
  @@index([senderId])
  @@index([isRead])
  @@index([type])
}
